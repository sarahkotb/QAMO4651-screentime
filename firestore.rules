rules_version = '2';
// QAMO 4651 — Screen Time Demonstration
// Paste these into Firebase console → Firestore Database → Rules → Publish.
//
// Students may READ and CREATE submissions (so the projector count + population
// update live). Nobody may edit or delete via the web app — that keeps students
// from tampering with the class data. (You can still delete from the console.)
// Creates are validated: a section of "001"/"002" and minutes in 0..1440.

service cloud.firestore {
  match /databases/{database}/documents {
    match /submissions/{doc} {
      allow read: if true;

      allow create: if request.resource.data.section in ['001','002']
                    && request.resource.data.minutes is int
                    && request.resource.data.minutes >= 0
                    && request.resource.data.minutes <= 1440
                    && request.resource.data.day is string;

      allow update, delete: if false;
    }
  }
}
